{
  "name": "hikahquest-native-shell",
  "version": "1.0.0",
  "private": true,
  "description": "Native shell packaging for HikahQuest",
  "scripts": {
    "build:banks": "node scripts/build-category-banks.mjs",
    "prepare:native": "node scripts/prepare-native-web.mjs",
    "cap:sync": "npm run prepare:native && npx cap sync",
    "cap:add:android": "npm run prepare:native && npx cap add android",
    "cap:add:ios": "npm run prepare:native && npx cap add ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capgo/capacitor-bluetooth-low-energy": "^8.0.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4"
  }
}
